# Quick Examples (Type-Safe Supabase Usage)

> Replace `<table>` and column names with your real ones.

### 1) Strongly-typed Supabase client

```ts
// lib/db.ts (example path)
import { createClient } from '@supabase/supabase-js';
import type { Database } from '@/types/database-all.types';

// Single, centralized client. Exported as `db`.
export const db = createClient<Database>(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_ANON_KEY! // or service role on server-only modules
);
```

```ts
// lib/supabase/server.ts
import { createClient } from '@supabase/supabase-js';
import { Database } from '@/types/database-all.types';

export const supabase = createClient<Database>(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY! // or anon key on client
);
```

### 2) Typed SELECT (read)

````ts
import { db } from '@/lib/db';
import type { Database } from '@/types/database-all.types';

type VehicleRow = Database['public']['Tables']['vehicles']['Row'];

export async function getVehicleById(id: string): Promise<VehicleRow | null> {
  const { data, error } = await db
    .from('vehicles')
    .select('*')
    .eq('id', id)
    .single();

  if (error) throw error;
  return data;
}
```ts
import { supabase } from '@/lib/supabase/server';
import { Database } from '@/types/database-all.types';

type VehicleRow = Database['public']['Tables']['vehicles']['Row'];

export async function getVehicleById(id: string): Promise<VehicleRow | null> {
  const { data, error } = await supabase
    .from('vehicles')
    .select('*')
    .eq('id', id)
    .single();

  if (error) throw error; // handle centrally in your API layer
  return data; // typed as VehicleRow | null
}
````

