### 5) Derived types via `Pick`/`Omit` (no shadow DTOs)

```ts
import { Database } from '@/types/database-all.types';

type VehicleRow = Database['public']['Tables']['vehicles']['Row'];
// Example: public card view without internals
export type VehicleCard = Pick<VehicleRow, 'id' | 'make' | 'model' | 'price' | 'thumbnail_url'>;
```

### 6) Runtime validation aligned with DB types (Zod)

```ts
import { z } from 'zod';
import { Database } from '@/types/database-all.types';

type VehicleInsert = Database['public']['Tables']['vehicles']['Insert'];

export const vehicleInsertSchema: z.ZodType<VehicleInsert> = z.object({
  id: z.string().uuid().optional(),
  make: z.string().min(1),
  model: z.string().min(1),
  price: z.number().nonnegative(),
  thumbnail_url: z.string().url().optional(),
  // ... add remaining fields to mirror your DB exactly
});
```

